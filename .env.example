# Postgres (Neon). For this project's scale, the direct (non-pooled) connection
# string is fine for both runtime and migrations - no need for a separate
# pooled/direct URL split.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Vercel Cron auth (Vercel sends this automatically as a Bearer header)
CRON_SECRET="generate-a-random-string"

# Tracker.gg official API key (optional - leave unset to use manual elo entry)
TRACKER_API_KEY=""
