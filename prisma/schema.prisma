// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  COACH
  PLAYER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum EventType {
  TRAINING
  SCRIM
  TOURNAMENT_MATCH
  MEETING
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
}

enum TournamentRegistrationStatus {
  PLANNED
  REGISTERED
  CONFIRMED
  COMPLETED
  WITHDRAWN
}

model Team {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       User[]                       @relation("TeamMembers")
  coaches       User[]                       @relation("TeamCoaches")
  coachLinks    CoachAssignment[]
  events        Event[]
  registrations TeamTournamentRegistration[]
}

model CoachAssignment {
  id     String @id @default(cuid())
  userId String
  teamId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  passwordHash String?
  role         Role      @default(PLAYER)
  isIgl        Boolean   @default(false)
  isCaptain    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teamId String?
  team   Team?   @relation("TeamMembers", fields: [teamId], references: [id])

  coachAssignments CoachAssignment[]
  coachTeams       Team[]            @relation("TeamCoaches")

  riotAccount   RiotAccount?
  invitesSent   Invite[]      @relation("InviteCreatedBy")
  eventInvites  EventInvite[]
  createdEvents Event[]       @relation("EventCreatedBy")
}

model Invite {
  id         String       @id @default(cuid())
  email      String
  token      String       @unique @default(cuid())
  role       Role
  teamId     String?
  status     InviteStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime     @default(now())
  acceptedAt DateTime?

  createdById String
  createdBy   User   @relation("InviteCreatedBy", fields: [createdById], references: [id])

  @@index([email])
  @@index([status])
}

model RiotAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gameName       String
  tagLine        String
  region         String?
  verifiedAt     DateTime?
  cachedCurrentRr Int?
  cachedCurrentTier String?
  cachedPeakRr   Int?
  cachedPeakTier String?
  lastFetchedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  eloSnapshots EloSnapshot[]

  @@unique([gameName, tagLine])
}

model EloSnapshot {
  id            String      @id @default(cuid())
  riotAccountId String
  riotAccount   RiotAccount @relation(fields: [riotAccountId], references: [id], onDelete: Cascade)

  currentRr     Int?
  currentTier   String?
  peakRr        Int?
  peakTier      String?
  source        String   @default("tracker.gg")
  raw           Json?
  isManualEntry Boolean  @default(false)
  fetchedAt     DateTime @default(now())

  @@index([riotAccountId, fetchedAt])
}

model Event {
  id          String    @id @default(cuid())
  type        EventType
  title       String
  description String?
  startsAt    DateTime
  endsAt      DateTime?
  location    String?

  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])

  createdById String
  createdBy   User   @relation("EventCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invites EventInvite[]

  @@unique([teamId, tournamentId, type])
  @@index([teamId, startsAt])
}

model EventInvite {
  id          String     @id @default(cuid())
  eventId     String
  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  status      RsvpStatus @default(PENDING)
  respondedAt DateTime?
  createdAt   DateTime   @default(now())

  @@unique([eventId, userId])
  @@index([userId, status])
}

model Tournament {
  id          String    @id @default(cuid())
  name        String
  organizer   String?
  startDate   DateTime
  endDate     DateTime?
  description String? // sanitized HTML from the rich text editor
  imageUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  registrations TeamTournamentRegistration[]
  events        Event[]
}

model TeamTournamentRegistration {
  id           String                       @id @default(cuid())
  teamId       String
  team         Team                         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tournamentId String
  tournament   Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  status       TournamentRegistrationStatus @default(PLANNED)
  registeredAt DateTime                     @default(now())
  notes        String?

  @@unique([teamId, tournamentId])
}
